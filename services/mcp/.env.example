# Bundestag DIP API Key (required)
# Public test key valid until 05/2027: R2BZaee.DjdCyihKZMf8AOjtScubP2EVydegzjmBIQ
# Request your own key: parlamentsdokumentation@bundestag.de
DIP_API_KEY=R2BZaee.DjdCyihKZMf8AOjtScubP2EVydegzjmBIQ

# Server Configuration (optional)
PORT=3000
PUBLIC_URL=

# Logging (optional)
# Options: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# NLP Analysis Service (optional)
# Python FastAPI service from bundestag-noun-analysis
# Provides speech extraction, tone analysis, topic classification, speaker profiles
# Local: http://localhost:5173  Production: https://bundestag-wrapped.de
ANALYSIS_SERVICE_URL=http://localhost:5173

# Expose the indexing/reindex tools (optional, default false)
# The 4 indexing tools (trigger_indexing, trigger_document_indexing,
# trigger_protocol_indexing, reindex_protocols) mutate/reset server-side jobs and
# are hidden from the MCP tool surface by default. The background indexer runs on
# its own schedule regardless. Set to true only on a local/admin instance.
EXPOSE_INDEXING_TOOLS=false
